    {
      "id": "lBL5-77fG0OiolIdpgnBn",
      "type": "text",
      "x": 6869.577018645779,
      "y": -20289.627893256118,
      "width": 3037.01806640625,
      "height": 9730,
      "angle": 0,
      "strokeColor": "#1e1e1e",
