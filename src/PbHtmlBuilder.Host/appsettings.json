{
  "$schema": "../../appsettings.schema.json",
  "PbHtmlBuilder": {
    "WorkingDirectory": {
      "RootMode": "AppDirectory",
      "RootPath": null
    },
    "RuntimeAssets": {
      "DevelopmentBaseUrl": "/runtime/student/",
      "ExportBaseUrl": "https://example.invalid/pb-html-builder/runtime/student/",
      "RuntimeChannel": "local"
    },
    "Dependencies": {
      "MonacoVersion": "pinned-later",
      "MonacoBaseUrl": "https://cdn.jsdelivr.net/npm/monaco-editor/",
      "PyodideVersion": "pinned-later",
      "PyodideBaseUrl": "https://cdn.jsdelivr.net/pyodide/"
    },
    "Server": {
      "PreferredPort": 5282
    },
    "Defaults": {
      "TopicKicker": "Python Bootcamp",
      "Copyright": "© Ivan Ivanov, 2026",
      "BrandName": "PbHtmlBuilder"
    },
    "Runtime": {
      "PythonTimeout": "00:00:10"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
