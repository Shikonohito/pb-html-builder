@page "/builder/theory"
@inject TheoryDocumentFactory DocumentFactory

@if (_document is not null)
{
    <BuilderWorkspaceShell DocumentKind="Theory"
                           DocumentTitle="@_document.DocumentTitle"
                           Accent="#4cc9f0"
                           OutlineLabel="Оглавление"
                           MapLabel="Разделы темы"
                           MapTitle="Что важно рассмотреть"
                           PrimarySectionTitle="@PrimarySectionTitle"
                           SidebarFooter="@_document.Brand.Copyright"
                           OutlineItems="OutlineItems"
                           CanvasItems="@CanvasItems"
                           TheoryDocument="_document"
                           OnTheoryDocumentChanged="UpdateDocument" />
}

@code {
    private static readonly string[] OutlineItems =
    [
        "Section map"
    ];

    [SupplyParameterFromQuery(Name = "title")]
    public string? Title { get; set; }

    [SupplyParameterFromQuery(Name = "folderPath")]
    public string? FolderPath { get; set; }

    [SupplyParameterFromQuery(Name = "fileName")]
    public string? FileName { get; set; }

    private TheoryDocument? _document;

    private string PrimarySectionTitle => _document?.Sections.FirstOrDefault()?.Title ?? "Introduction";

    private IReadOnlyList<string> CanvasItems => _document?.SectionMapCells
        .Select(cell => cell.Title)
        .ToArray() ?? [];

    protected override void OnParametersSet()
    {
        _document ??= DocumentFactory.CreateNew(new TheoryDocumentCreateRequest(FolderPath, FileName, Title));
    }

    private void UpdateDocument(TheoryDocument document)
    {
        _document = document;
    }
}
