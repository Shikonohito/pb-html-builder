<div class="project-dialog-backdrop" role="presentation" @onclick="OnClose">
    <div class="project-dialog is-save-as" role="dialog" aria-modal="true" aria-labelledby="saveAsDialogTitle" @onclick:stopPropagation="true">
        <div class="project-dialog-head">
            <h3 id="saveAsDialogTitle">Save as...</h3>
            <button class="project-dialog-icon-button" type="button" title="Close" aria-label="Close" @onclick="OnClose">×</button>
        </div>

        @if (Errors.Count > 0)
        {
            <div class="project-dialog-errors" role="alert">
                @foreach (var error in Errors)
                {
                    <p>@error</p>
                }
            </div>
        }

        <form class="project-dialog-form" @onsubmit="Submit" @onsubmit:preventDefault="true">
            <FileSystemPicker CurrentPath="@PickerPath"
                              DefaultPath="projects/theory"
                              AllowFileSelection="true"
                              OnFolderSelected="SelectFolder"
                              OnFileSelected="SelectFile" />

            <label for="saveAsFileName">
                <span>File name</span>
                <input id="saveAsFileName"
                       type="text"
                       autocomplete="off"
                       placeholder="lesson-theory.html"
                       @bind="_fileName"
                       @bind:event="oninput" />
            </label>

            <div class="project-dialog-actions">
                <button class="project-primary-button" type="submit">Save</button>
                <button class="project-secondary-button" type="button" @onclick="OnClose">Cancel</button>
            </div>
        </form>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public required DocumentTarget CurrentTarget { get; set; }

    [Parameter]
    public IReadOnlyList<string> Errors { get; set; } = [];

    [Parameter]
    public EventCallback<DocumentTarget> OnSubmitted { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private string _folderPath = "";
    private string _fileName = "";
    private bool _initialized;

    private string PickerPath => string.IsNullOrWhiteSpace(_folderPath)
        ? "projects/theory"
        : _folderPath;

    protected override void OnParametersSet()
    {
        if (_initialized)
        {
            return;
        }

        _folderPath = CurrentTarget.FolderPath;
        _fileName = CurrentTarget.FileName;
        _initialized = true;
    }

    private void SelectFolder(string path)
    {
        _folderPath = path;
    }

    private void SelectFile(FolderBrowseEntry entry)
    {
        _folderPath = entry.SelectionPath;
        _fileName = entry.Name;
    }

    private Task Submit()
    {
        return OnSubmitted.InvokeAsync(DocumentTarget.Create(_folderPath, _fileName));
    }
}
