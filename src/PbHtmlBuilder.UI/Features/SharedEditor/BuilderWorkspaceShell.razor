@inject TheoryProjectSaveUseCase SaveUseCase

<PageTitle>@ResolvedDocumentTitle - PbHtmlBuilder</PageTitle>

<div class="builder-workspace @(_isSidebarCollapsed ? "is-sidebar-collapsed" : "")"
     style="@($"--builder-accent: {Accent}")"
     @oncontextmenu="OpenProjectContextMenu"
     @oncontextmenu:preventDefault="ProjectCommandsAvailable">
    <header class="builder-topbar">
        <button class="builder-icon-button"
                type="button"
                title="Toggle sidebar"
                aria-label="Toggle sidebar"
                aria-expanded="@SidebarExpanded"
                @onclick="ToggleSidebar">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 6h16" />
                <path d="M4 12h16" />
                <path d="M4 18h16" />
            </svg>
        </button>

        <div class="builder-topic-title">
            <span>@Kicker</span>
            <h1>@ResolvedDocumentTitle</h1>
        </div>
    </header>

    <aside class="builder-sidebar" aria-label="@OutlineLabel">
        <div class="builder-sidebar-head">
            <span>@OutlineLabel</span>
            <button class="builder-panel-button"
                    type="button"
                    title="Collapse sidebar"
                    aria-label="Collapse sidebar"
                    @onclick="ToggleSidebar">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="m15 18-6-6 6-6" />
                </svg>
            </button>
        </div>

        <nav class="builder-outline" aria-label="@OutlineLabel">
            @if (TheoryDocument is not null)
            {
                @for (var index = 0; index < ResolvedSections.Count; index++)
                {
                    var section = ResolvedSections[index];

                    <InsertionRail InsertIndex="@index"
                                   Variant="sidebar"
                                   AriaLabel="@($"Добавить секцию перед {FormatSectionNumber(index)}")"
                                   OnInsert="InsertSection" />

                    <button @key="section.Id"
                            class="builder-outline-item @(index == 0 ? "is-current" : null)"
                            type="button"
                            aria-current="@(index == 0 ? "true" : null)">
                        <span>@FormatSectionNumber(index)</span>
                        <strong>@section.Title</strong>
                    </button>
                }

                @if (ResolvedSections.Count > 0)
                {
                    <InsertionRail InsertIndex="@ResolvedSections.Count"
                                   Variant="sidebar"
                                   AriaLabel="Добавить секцию в конец"
                                   OnInsert="InsertSection" />
                }
            }
            else if (PrimaryOutlineItem is { } outlineItem)
            {
                <button class="builder-outline-item is-current"
                        type="button"
                        aria-current="true">
                    <span>01</span>
                    <strong>@outlineItem</strong>
                </button>
            }
        </nav>

        @if (!string.IsNullOrWhiteSpace(SidebarFooter))
        {
            <div class="builder-sidebar-footer">@SidebarFooter</div>
        }
    </aside>

    <main class="builder-main" aria-label="@($"{DocumentKind} builder")">
        @if (ShowSectionMap)
        {
            <section class="builder-section-map" aria-label="@MapTitle">
                <div>
                    <span>@MapLabel</span>
                    <h3>@MapTitle</h3>
                </div>
                <div class="builder-section-map-grid">
                    @foreach (var canvasItem in ResolvedCanvasItems)
                    {
                        <button type="button">@canvasItem</button>
                    }
                </div>
            </section>
        }

        <article class="builder-section-skeleton">
            @if (TheoryDocument is null)
            {
                <section class="builder-section">
                    <div class="builder-section-heading section-heading">
                        <span>01</span>
                        <h3>@PrimarySectionTitle</h3>
                    </div>
                </section>
            }
            else if (ResolvedSections.Count == 0)
            {
                <InsertionRail InsertIndex="0"
                               Variant="empty"
                               AriaLabel="Добавить первую секцию"
                               OnInsert="InsertSection" />
            }
            else
            {
                @for (var index = 0; index < ResolvedSections.Count; index++)
                {
                    var section = ResolvedSections[index];

                    <InsertionRail InsertIndex="@index"
                                   Variant="main"
                                   AriaLabel="@($"Добавить секцию перед {FormatSectionNumber(index)}")"
                                   OnInsert="InsertSection" />

                    <section @key="section.Id"
                             id="@section.Id"
                             class="builder-section"
                             data-section-id="@section.Id">
                        <div class="builder-section-heading section-heading">
                            <span>@FormatSectionNumber(index)</span>
                            <h3>@section.Title</h3>
                        </div>
                    </section>
                }

                <InsertionRail InsertIndex="@ResolvedSections.Count"
                               Variant="main"
                               AriaLabel="Добавить секцию в конец"
                               OnInsert="InsertSection" />
            }
        </article>
    </main>
</div>

@if (_isProjectContextMenuOpen)
{
    <ProjectContextMenu @key="_projectContextMenuSession"
                        X="_projectContextMenuX"
                        Y="_projectContextMenuY"
                        OnSave="SaveProject"
                        OnSaveAs="OpenSaveAsDialog"
                        OnOpenAtPointer="OpenProjectContextMenu"
                        OnClose="CloseProjectContextMenu" />
}

@if (_isSaveAsDialogOpen && TheoryDocument is not null)
{
    <SaveAsDialog CurrentTarget="TheoryDocument.Target"
                  Errors="_saveAsErrors"
                  OnSubmitted="SaveProjectAs"
                  OnClose="CloseSaveAsDialog" />
}

@if (_confirmation is not null)
{
    <ProjectConfirmationDialog Title="@_confirmation.Title"
                               Message="@_confirmation.Message"
                               ConfirmLabel="@_confirmation.ConfirmLabel"
                               OnConfirm="ConfirmPendingSave"
                               OnCancel="CancelPendingSave" />
}

@if (_toast is not null)
{
    <div @key="_toastSession" class="builder-save-toast @(_toast.IsError ? "is-error" : "is-success")" role="status">
        @_toast.Message
    </div>
}

@code {
    private static readonly string[] DefaultOutlineItems =
    [
        "Section map"
    ];

    private static readonly string[] DefaultCanvasItems =
    [
        "Intro",
        "Concept",
        "Example",
        "Practice",
        "Review",
        "Summary"
    ];

    [Parameter, EditorRequired]
    public required string DocumentKind { get; set; }

    [Parameter]
    public string Kicker { get; set; } = "Python Bootcamp";

    [Parameter]
    public string? DocumentTitle { get; set; }

    [Parameter]
    public string Accent { get; set; } = "#4cc9f0";

    [Parameter]
    public string OutlineLabel { get; set; } = "Outline";

    [Parameter]
    public string MapTitle { get; set; } = "Section map";

    [Parameter]
    public string MapLabel { get; set; } = "Map";

    [Parameter]
    public bool ShowSectionMap { get; set; } = true;

    [Parameter]
    public string PrimarySectionTitle { get; set; } = "Untitled section";

    [Parameter]
    public string? SidebarFooter { get; set; }

    [Parameter]
    public IReadOnlyList<string> OutlineItems { get; set; } = DefaultOutlineItems;

    [Parameter]
    public IReadOnlyList<string> CanvasItems { get; set; } = DefaultCanvasItems;

    [Parameter]
    public TheoryDocument? TheoryDocument { get; set; }

    [Parameter]
    public EventCallback<TheoryDocument> OnTheoryDocumentChanged { get; set; }

    private bool _isSidebarCollapsed;
    private bool _isProjectContextMenuOpen;
    private double _projectContextMenuX;
    private double _projectContextMenuY;
    private int _projectContextMenuSession;
    private bool _isSaveAsDialogOpen;
    private IReadOnlyList<string> _saveAsErrors = [];
    private SaveConfirmation? _confirmation;
    private PendingSave? _pendingSave;
    private SaveToast? _toast;
    private int _toastSession;

    private string ResolvedDocumentTitle => string.IsNullOrWhiteSpace(DocumentTitle)
        ? TheoryDocument?.DocumentTitle ?? $"Untitled {DocumentKind}"
        : DocumentTitle.Trim();

    private IReadOnlyList<string> ResolvedOutlineItems => OutlineItems.Count == 0
        ? DefaultOutlineItems
        : OutlineItems;

    private string? PrimaryOutlineItem => ResolvedOutlineItems.Count == 0
        ? null
        : ResolvedOutlineItems[0];

    private IReadOnlyList<string> ResolvedCanvasItems => CanvasItems.Count == 0
        ? DefaultCanvasItems
        : CanvasItems;

    private IReadOnlyList<TheorySection> ResolvedSections => TheoryDocument?.Sections ?? [];

    private string SidebarExpanded => (!_isSidebarCollapsed).ToString().ToLowerInvariant();

    private bool ProjectCommandsAvailable => TheoryDocument is not null;

    private void ToggleSidebar()
    {
        _isSidebarCollapsed = !_isSidebarCollapsed;
    }

    private Task InsertSection(int index)
    {
        if (TheoryDocument is null)
        {
            return Task.CompletedTask;
        }

        var document = TheoryDocumentSectionInserter.Insert(TheoryDocument, index);
        return OnTheoryDocumentChanged.InvokeAsync(document);
    }

    private void OpenProjectContextMenu(MouseEventArgs args)
    {
        if (!ProjectCommandsAvailable)
        {
            return;
        }

        _projectContextMenuX = args.ClientX;
        _projectContextMenuY = args.ClientY;
        _projectContextMenuSession++;
        _isProjectContextMenuOpen = true;
        _saveAsErrors = [];
    }

    private void CloseProjectContextMenu()
    {
        _isProjectContextMenuOpen = false;
    }

    private Task SaveProject()
    {
        CloseProjectContextMenu();
        return ExecuteSaveAsync(new TheoryProjectSaveOptions());
    }

    private void OpenSaveAsDialog()
    {
        CloseProjectContextMenu();
        _saveAsErrors = [];
        _isSaveAsDialogOpen = true;
    }

    private void CloseSaveAsDialog()
    {
        _isSaveAsDialogOpen = false;
        _saveAsErrors = [];
    }

    private Task SaveProjectAs(DocumentTarget target)
    {
        return ExecuteSaveAsync(new TheoryProjectSaveOptions(
            TargetOverride: target,
            SaveAs: true));
    }

    private async Task ExecuteSaveAsync(TheoryProjectSaveOptions options)
    {
        if (TheoryDocument is null)
        {
            return;
        }

        var result = await SaveUseCase.SaveAsync(TheoryDocument, options);
        switch (result.Status)
        {
            case ProjectSaveStatus.Saved:
                _isSaveAsDialogOpen = false;
                _saveAsErrors = [];
                await OnTheoryDocumentChanged.InvokeAsync(result.Document);
                ShowToast(BuildSavedMessage(result), isError: false);
                break;

            case ProjectSaveStatus.RequiresCreateDirectoryConfirmation:
                _isSaveAsDialogOpen = false;
                _pendingSave = new PendingSave(options with { AllowCreateDirectory = true });
                _confirmation = new SaveConfirmation(
                    "Create folder?",
                    $"The folder for {result.RelativePath} does not exist. Create it?",
                    "Create");
                break;

            case ProjectSaveStatus.RequiresOverwriteConfirmation:
                _isSaveAsDialogOpen = false;
                _pendingSave = new PendingSave(options with { AllowOverwrite = true });
                _confirmation = new SaveConfirmation(
                    "Overwrite file?",
                    BuildOverwriteMessage(result),
                    "Overwrite");
                break;

            case ProjectSaveStatus.ValidationFailed:
                if (options.SaveAs)
                {
                    _saveAsErrors = result.Errors;
                    _isSaveAsDialogOpen = true;
                }
                else
                {
                    ShowToast(string.Join(" ", result.Errors), isError: true);
                }

                break;
        }
    }

    private async Task ConfirmPendingSave()
    {
        if (_pendingSave is not { } pendingSave)
        {
            _confirmation = null;
            return;
        }

        _pendingSave = null;
        _confirmation = null;
        await ExecuteSaveAsync(pendingSave.Options);
    }

    private void CancelPendingSave()
    {
        _pendingSave = null;
        _confirmation = null;
        ShowToast("Save canceled.", isError: true);
    }

    private void ShowToast(string message, bool isError)
    {
        var session = ++_toastSession;
        _toast = new SaveToast(message, isError);
        _ = ClearToastLaterAsync(session);
    }

    private async Task ClearToastLaterAsync(int session)
    {
        await Task.Delay(TimeSpan.FromSeconds(3.5));

        if (session == _toastSession)
        {
            _toast = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string BuildSavedMessage(TheoryProjectSaveResult result)
    {
        if (string.IsNullOrWhiteSpace(result.BackupRelativePath))
        {
            return $"Saved {result.RelativePath}.";
        }

        return $"Saved {result.RelativePath}. Backup: {result.BackupRelativePath}.";
    }

    private static string BuildOverwriteMessage(TheoryProjectSaveResult result)
    {
        var lastModified = result.LastModifiedAt is null
            ? "Last modified time is unavailable."
            : $"Last modified: {result.LastModifiedAt.Value.ToLocalTime():g}.";

        return $"Overwrite Theory HTML file {result.RelativePath}? {lastModified}";
    }

    private static string FormatSectionNumber(int index)
    {
        return (index + 1).ToString("00");
    }

    private sealed record SaveConfirmation(
        string Title,
        string Message,
        string ConfirmLabel);

    private sealed record PendingSave(TheoryProjectSaveOptions Options);

    private sealed record SaveToast(string Message, bool IsError);
}
