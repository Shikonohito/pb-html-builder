@inject IProjectFolderBrowser FolderBrowser

<div class="filesystem-picker">
    <div class="filesystem-toolbar" role="toolbar" aria-label="File system navigation">
        <button class="filesystem-tool-button"
                type="button"
                title="Up"
                aria-label="Up"
                disabled="@(_browse?.ParentPath is null)"
                @onclick="NavigateUp">
            <svg xmlns="http://www.w3.org/2000/svg"
                 width="24"
                 height="24"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="2"
                 stroke-linecap="round"
                 stroke-linejoin="round"
                 class="lucide lucide-arrow-up-icon lucide-arrow-up"
                 aria-hidden="true">
                <path d="m5 12 7-7 7 7" />
                <path d="M12 19V5" />
            </svg>
        </button>
        <button class="filesystem-tool-button"
                type="button"
                title="Project root"
                aria-label="Project root"
                @onclick="NavigateRoot">
            <svg xmlns="http://www.w3.org/2000/svg"
                 width="24"
                 height="24"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="2"
                 stroke-linecap="round"
                 stroke-linejoin="round"
                 class="lucide lucide-house-icon lucide-house"
                 aria-hidden="true">
                <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8" />
                <path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            </svg>
        </button>
        <button class="filesystem-tool-button"
                type="button"
                title="Refresh"
                aria-label="Refresh"
                @onclick="Refresh">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" />
                <path d="M3 21v-5h5" />
                <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" />
                <path d="M16 8h5V3" />
            </svg>
        </button>
    </div>

    <div class="filesystem-path-stack" aria-live="polite">
        <div>
            <span id="@_currentPathLabelId">Current</span>
            <span class="filesystem-path-input-row">
                <input class="filesystem-current-input"
                       type="text"
                       autocomplete="off"
                       aria-labelledby="@_currentPathLabelId"
                       value="@_currentPathInput"
                       @oninput="HandleCurrentPathInput"
                       @onchange="BrowseCurrentPathInput" />
                <button class="filesystem-path-button"
                        type="button"
                        title="Open path"
                        aria-label="Open path"
                        @onclick="BrowseCurrentPathInput">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>
            </span>
        </div>
    </div>

    @if (_browse?.Errors.Count > 0)
    {
        <div class="filesystem-errors" role="alert">
            @foreach (var error in _browse.Errors)
            {
                <p>@error</p>
            }
        </div>
    }

    <div class="filesystem-entry-list" role="listbox" aria-label="Files and folders">
        @if (_browse is null)
        {
            <div class="filesystem-empty">No folder loaded</div>
        }
        else
        {
            var directoryEntries = _browse.Entries
                .Where(entry => entry.Kind == FolderBrowseEntryKind.Directory)
                .ToArray();

            if (directoryEntries.Length == 0)
            {
                <div class="filesystem-empty">No folders found</div>
            }
            else
            {
                @foreach (var entry in directoryEntries)
                {
                    var isEnabled = entry.IsAccessible;
                    var isSelected = IsSelected(entry.SelectionPath);

                    <button @key="entry.FullPath"
                            class="filesystem-entry is-directory @(isSelected ? "is-selected" : "")"
                            type="button"
                            role="option"
                            aria-selected="@isSelected"
                            aria-disabled="@(!isEnabled)"
                            disabled="@(!isEnabled)"
                            title="@entry.FullPath"
                            @onclick="args => SelectEntry(entry, args)"
                            @ondblclick="args => OpenEntry(entry, args)">
                        <span class="filesystem-entry-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24">
                                <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            </svg>
                        </span>
                        <span class="filesystem-entry-name">@entry.Name</span>
                    </button>
                }
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public string CurrentPath { get; set; } = "projects/theory";

    [Parameter]
    public string DefaultPath { get; set; } = "projects/theory";

    [Parameter]
    public bool AllowFileSelection { get; set; }

    [Parameter]
    public bool OpenFoldersOnDoubleClick { get; set; }

    [Parameter]
    public EventCallback<string> OnFolderSelected { get; set; }

    [Parameter]
    public EventCallback<FolderBrowseEntry> OnFileSelected { get; set; }

    private FolderBrowseResponse? _browse;
    private string? _lastParameterPath;
    private string _selectedFolderPath = "";
    private string _currentPathInput = "";
    private readonly string _currentPathLabelId = $"filesystemCurrentPath_{Guid.NewGuid():N}";
    private const long PrimaryMouseButton = 0;

    protected override async Task OnParametersSetAsync()
    {
        var requestedPath = ResolveRequestedPath();
        if (_browse is not null
            && string.Equals(_lastParameterPath, requestedPath, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _lastParameterPath = requestedPath;
        await BrowseToAsync(requestedPath);
    }

    private string ResolveRequestedPath()
    {
        return string.IsNullOrWhiteSpace(CurrentPath) ? DefaultPath : CurrentPath.Trim();
    }

    private async Task BrowseToAsync(string? path)
    {
        var requestedPath = string.IsNullOrWhiteSpace(path) ? DefaultPath : path;
        _browse = FolderBrowser.Browse(requestedPath);
        _currentPathInput = _browse.RequestedDisplayPath;
        _selectedFolderPath = _browse.RequestedSelectionPath;
        await OnFolderSelected.InvokeAsync(_browse.RequestedSelectionPath);
    }

    private async Task HandleCurrentPathInput(ChangeEventArgs args)
    {
        _currentPathInput = args.Value?.ToString() ?? "";
        _selectedFolderPath = ResolveCurrentPathInput();
        await OnFolderSelected.InvokeAsync(_selectedFolderPath);
    }

    private Task BrowseCurrentPathInput()
    {
        return BrowseToAsync(ResolveCurrentPathInput());
    }

    private string ResolveCurrentPathInput()
    {
        return string.IsNullOrWhiteSpace(_currentPathInput)
            ? DefaultPath
            : _currentPathInput.Trim();
    }

    private async Task SelectEntry(FolderBrowseEntry entry, MouseEventArgs args)
    {
        if (!entry.IsAccessible || !IsPrimaryMouseButton(args))
        {
            return;
        }

        if (entry.Kind == FolderBrowseEntryKind.Directory)
        {
            if (OpenFoldersOnDoubleClick)
            {
                _selectedFolderPath = entry.SelectionPath;
                await OnFolderSelected.InvokeAsync(entry.SelectionPath);
            }
            else
            {
                await BrowseToAsync(entry.FullPath);
            }

            return;
        }

        if (AllowFileSelection)
        {
            _selectedFolderPath = entry.SelectionPath;
            await OnFileSelected.InvokeAsync(entry);
        }
    }

    private async Task OpenEntry(FolderBrowseEntry entry, MouseEventArgs args)
    {
        if (!OpenFoldersOnDoubleClick
            || !entry.IsAccessible
            || entry.Kind != FolderBrowseEntryKind.Directory
            || !IsPrimaryMouseButton(args))
        {
            return;
        }

        await BrowseToAsync(entry.FullPath);
    }

    private async Task NavigateUp()
    {
        if (_browse?.ParentPath is { } parentPath)
        {
            await BrowseToAsync(parentPath);
        }
    }

    private Task NavigateRoot()
    {
        return BrowseToAsync(".");
    }

    private Task Refresh()
    {
        return BrowseToAsync(_browse?.CurrentPath ?? ResolveRequestedPath());
    }

    private bool IsSelected(string path)
    {
        return string.Equals(
            path,
            _selectedFolderPath,
            StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsPrimaryMouseButton(MouseEventArgs args)
    {
        return args.Button == PrimaryMouseButton;
    }
}
