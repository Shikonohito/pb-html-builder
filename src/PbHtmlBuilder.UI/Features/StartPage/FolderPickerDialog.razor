<div class="folder-dialog-backdrop" style="@($"--action-accent: {ActionAccent};")" role="presentation" @onclick="OnClose">
    <div class="folder-dialog" role="dialog" aria-modal="true" aria-labelledby="folderDialogTitle" @onclick:stopPropagation="true">
        <div class="folder-dialog-head">
            <h3 id="folderDialogTitle">Choose folder</h3>
            <button class="dialog-icon-button" type="button" title="Close" aria-label="Close" @onclick="OnClose">
                <svg xmlns="http://www.w3.org/2000/svg"
                     width="24"
                     height="24"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="2"
                     stroke-linecap="round"
                     stroke-linejoin="round"
                     class="lucide lucide-x-icon lucide-x"
                     aria-hidden="true">
                    <path d="M18 6 6 18" />
                    <path d="m6 6 12 12" />
                </svg>
            </button>
        </div>

        <FileSystemPicker CurrentPath="@InitialPickerPath"
                          DefaultPath="@FolderPathPlaceholder"
                          AllowFileSelection="false"
                          OpenFoldersOnDoubleClick="true"
                          OnFolderSelected="SelectInDialog" />

        <div class="dialog-actions">
            <button class="create-button" type="button" @onclick="SelectManualPath">Select</button>
            <button class="cancel-button" type="button" @onclick="OnClose">Cancel</button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string CurrentPath { get; set; } = "";

    [Parameter]
    public string FolderPathPlaceholder { get; set; } = "projects/theory";

    [Parameter]
    public string ActionAccent { get; set; } = "#4cc9f0";

    [Parameter]
    public EventCallback<string> OnSelected { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private string _selectedPath = "";

    private string InitialPickerPath => string.IsNullOrWhiteSpace(CurrentPath)
        ? FolderPathPlaceholder
        : CurrentPath;

    protected override void OnParametersSet()
    {
        _selectedPath = InitialPickerPath;
    }

    private void SelectInDialog(string path)
    {
        _selectedPath = path;
    }

    private Task SelectManualPath()
    {
        return OnSelected.InvokeAsync(_selectedPath.Trim());
    }
}
