@page "/"

<PageTitle>PbHtmlBuilder</PageTitle>
<div class="start-page">
    <h1 class="sr-only">PbHtmlBuilder</h1>

    <section class="start-shell" aria-label="Start workspace">
        <div class="start-slider @(_isCreateVisible ? "is-create" : "is-actions")">
            <div class="start-slide" aria-hidden="@_isCreateVisible" inert="@(_isCreateVisible ? string.Empty : null)">
                <div class="start-panel">
                    <NewActionPanel OnSelected="SelectAction" />
                    <RecentProjectsList />
                </div>
            </div>

            <div class="start-slide" aria-hidden="@(!_isCreateVisible)" inert="@(!_isCreateVisible ? string.Empty : null)">
                <div class="start-panel">
                    @if (_mountedAction is { } mountedAction)
                    {
                        <CreateDocumentForm Action="mountedAction" OnCancel="CancelCreate" />
                    }
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private static readonly TimeSpan StartSliderTransitionDuration = TimeSpan.FromMilliseconds(340);

    private StartDocumentAction? _mountedAction;
    private bool _isCreateVisible;
    private int _transitionSession;

    private void SelectAction(StartDocumentAction action)
    {
        _transitionSession++;
        _mountedAction = action;
        _isCreateVisible = true;
    }

    private async Task CancelCreate()
    {
        var session = ++_transitionSession;
        _isCreateVisible = false;

        await Task.Delay(StartSliderTransitionDuration);

        if (session == _transitionSession && !_isCreateVisible)
        {
            _mountedAction = null;
        }
    }
}
