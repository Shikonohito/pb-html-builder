@inject NavigationManager Navigation
@inject IProjectFolderBrowser FolderBrowser

<div class="create-document" style="@($"--action-accent: {Action.Accent}")">
    <div class="create-document-head">
        <span class="create-document-icon" aria-hidden="true">@((MarkupString)GetActionIcon(Action.Key))</span>
        <h2>@Action.Label</h2>
    </div>

    <form class="create-document-form" @onsubmit="HandleCreate" @onsubmit:preventDefault="true">
        <label class="field-group" for="folderPath">
            <span>Save path</span>
            <span class="path-input-row">
                <input id="folderPath"
                       name="folderPath"
                       type="text"
                       autocomplete="off"
                       placeholder="@_folderPathPlaceholder"
                       value="@FolderPath"
                       @oninput="HandleFolderPathInput" />
                <button class="folder-picker-button"
                        type="button"
                        title="Choose folder"
                        aria-label="Choose folder"
                        @onclick="OnFolderPickerOpen">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"/></svg>
                </button>
            </span>
        </label>

        <label class="field-group" for="fileName">
            <span>File name</span>
            <input id="fileName"
                   name="fileName"
                   type="text"
                   autocomplete="off"
                   placeholder="@Action.FileNamePlaceholder"
                   @bind="_fileName"
                   @bind:event="oninput" />
        </label>

        <label class="field-group" for="documentTitle">
            <span>Document title</span>
            <input id="documentTitle"
                   name="documentTitle"
                   type="text"
                   autocomplete="off"
                   placeholder="@GetDocumentTitlePlaceholder(Action.Key)"
                   @bind="_documentTitle"
                   @bind:event="oninput" />
        </label>

        <div class="create-actions">
            <button class="create-button" type="submit">Create</button>
            <button class="cancel-button" type="button" @onclick="OnCancel">Cancel</button>
        </div>
    </form>
</div>

@code {
    [Parameter, EditorRequired]
    public required StartDocumentAction Action { get; set; }

    [Parameter]
    public string FolderPath { get; set; } = "";

    [Parameter]
    public EventCallback<string> FolderPathChanged { get; set; }

    [Parameter]
    public EventCallback OnFolderPickerOpen { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private string _fileName = "";
    private string _documentTitle = "";
    private string _folderPathPlaceholder = "";

    protected override void OnParametersSet()
    {
        _folderPathPlaceholder = ResolveFolderPathPlaceholder();
    }

    private Task HandleFolderPathInput(ChangeEventArgs args)
    {
        return FolderPathChanged.InvokeAsync(args.Value?.ToString() ?? "");
    }

    private string ResolveFolderPathPlaceholder()
    {
        if (string.IsNullOrWhiteSpace(Action.FolderPathPlaceholder))
        {
            return Action.FolderPathPlaceholder;
        }

        return FolderBrowser.Browse(Action.FolderPathPlaceholder).RequestedDisplayPath;
    }

    private void HandleCreate()
    {
        var builderRoute = GetBuilderRoute(Action.Key);
        if (builderRoute is null)
        {
            return;
        }

        Navigation.NavigateTo(BuildBuilderUri(builderRoute));
    }

    private string BuildBuilderUri(string route)
    {
        var queryParameters = new List<string>();

        AddQueryParameter(queryParameters, "folderPath", FolderPath.Trim().Replace('\\', '/'));
        AddQueryParameter(queryParameters, "fileName", _fileName.Trim());
        AddQueryParameter(queryParameters, "title", ResolveDocumentTitle());

        return queryParameters.Count == 0
            ? route
            : $"{route}?{string.Join("&", queryParameters)}";
    }

    private string ResolveDocumentTitle()
    {
        if (!string.IsNullOrWhiteSpace(_documentTitle))
        {
            return _documentTitle.Trim();
        }

        var fileName = _fileName.Trim();
        if (!string.IsNullOrWhiteSpace(fileName))
        {
            var extensionIndex = fileName.LastIndexOf('.');
            return extensionIndex > 0 ? fileName[..extensionIndex] : fileName;
        }

        return GetDefaultDocumentTitle(Action.Key);
    }

    private static void AddQueryParameter(List<string> queryParameters, string name, string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        queryParameters.Add($"{name}={Uri.EscapeDataString(value)}");
    }

    private static string? GetBuilderRoute(string key) => key switch
    {
        "theory" => "/builder/theory",
        "practice" => "/builder/practice",
        "assessment" => "/builder/assessment",
        _ => null
    };

    private static string GetDefaultDocumentTitle(string key) => key switch
    {
        "theory" => "Название урока",
        "practice" => "Название практики",
        "assessment" => "Название контрольной работы",
        _ => "Document"
    };

    private static string GetDocumentTitlePlaceholder(string key) => key switch
    {
        "theory" => "Lesson title",
        "practice" => "Practice title",
        "assessment" => "Assessment title",
        _ => "Document title"
    };

    private static string GetActionIcon(string key) => key switch
    {
        "theory" => """
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M16 12h2"/><path d="M16 8h2"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/><path d="M6 12h2"/><path d="M6 8h2"/></svg>
            """,
        "practice" => """
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 11 2-2-2-2"/><path d="M11 13h4"/><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/></svg>
            """,
        "assessment" => """
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
            """,
        _ => """
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="m9 15 2 2 4-4"/></svg>
            """
    };
}
